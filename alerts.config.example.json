{
  "name": "templedao-migration-backing-alerts",
  "enabled": true,
  "source": {
    "contract": "0x2222222222222222222222222222222222222222",
    "event": "TelegramAlertRequested(bytes32,bytes32,address,uint256,uint256,uint256,address,address,uint256,bytes32)"
  },
  "webhook": {
    "url": "https://YOUR_WEBHOOK_HOST/drosera/templedao",
    "method": "POST",
    "headers": {
      "content-type": "application/json",
      "x-webhook-secret": "replace_with_WEBHOOK_SECRET"
    }
  },
  "telegram": {
    "botTokenEnv": "TELEGRAM_BOT_TOKEN",
    "chatIdEnv": "TELEGRAM_CHAT_ID"
  }
}
